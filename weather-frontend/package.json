{
  "name": "weather-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "overrides": {
    "path-to-regexp": ">=6.3.1",
    "minimatch": ">=9.0.7"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:integration": "cypress run --spec cypress/e2e/real-integration.cy.ts",
    "test:integration": "start-server-and-test dev http://localhost:3000 cypress:integration"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^1.6.1",
    "cypress": "^15.13.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^24.1.3",
    "msw": "^2.13.6",
    "start-server-and-test": "^3.0.0",
    "typescript": "^5.0.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.1",
    "wait-on": "^9.0.4"
  }
}
